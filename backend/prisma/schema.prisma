datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  role        Role     @default(CUSTOMER)
  balance     Decimal  @default(0.0) // Wallet for Commissions & Pi Network
  createdAt   DateTime @default(now())
  orders      Order[]
}

enum Role {
  CUSTOMER
  RIDER
  MERCHANT
  ADMIN
}

model Store {
  id        String    @id @default(uuid())
  name      String    // e.g., Panda Supermarket
  image     String?
  category  String    // Restaurant or Supermarket
  rating    Float     @default(5.0)
  products  Product[]
  orders    Order[]
}

model Product {
  id      String  @id @default(uuid())
  name    String
  price   Decimal
  image   String?
  storeId String
  store   Store   @relation(fields: [storeId], references: [id])
}

model Order {
  id           String      @id @default(uuid())
  status       OrderStatus @default(PENDING)
  totalPrice   Decimal
  commission   Decimal     // Forsale Platform Fee
  customerId   String
  customer     User        @relation(fields: [customerId], references: [id])
  storeId      String
  store        Store       @relation(fields: [storeId], references: [id])
  paymentType  String      @default("CASH") // CASH, PI_NETWORK, CARD
  createdAt    DateTime    @default(now())
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PICKING_UP
  ON_THE_WAY
  DELIVERED
}
